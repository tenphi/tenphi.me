# AT Protocol / standard.site publishing credentials.
# Copy to .env (gitignored) and fill in. Used by `pnpm publish:atproto`.

# Bluesky handle used to log in and as the public publication identity.
ATPROTO_HANDLE=tenphi.bsky.social

# A Bluesky APP PASSWORD (Settings -> Privacy and security -> App passwords).
# Never use your main account password.
ATPROTO_PASSWORD=

# Optional: override the PDS host if you self-host (default: https://bsky.social).
# ATPROTO_PDS=https://bsky.social
