---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container';
import Stack from '../../components/ui/Stack';
import Link from '../../components/ui/Link';
import ArticleContent from '../../components/ArticleContent';
import Tag from '../../components/ui/Tag';
import EngagementBar from '../../components/EngagementBar';
import BlueskyComments from '../../components/BlueskyComments';
import { tasty } from '@tenphi/tasty';
import readingTime from 'reading-time';
import { site } from '../../config/site';
import { getPostThread, getProfile } from '../../lib/bluesky';
import atprotoRecords from '../../config/atproto-records.json';

interface DocumentRecord {
  rkey: string;
  atUri: string;
  bskyPost?: { uri: string; cid: string };
}

const records = atprotoRecords as {
  did: string | null;
  publication: { rkey: string; atUri: string } | null;
  documents: Record<string, DocumentRecord>;
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { text: readTime } = readingTime(post.body ?? '');

const documentRecord = records.documents[post.id];
const bskyPostUri = documentRecord?.bskyPost?.uri;
const thread = bskyPostUri ? await getPostThread(bskyPostUri) : null;
const profile = thread ? await getProfile() : null;

const Heading = tasty({
  as: 'h1',
  styles: {
    preset: 'h1',
    color: '#text',
    margin: '0',
    viewTransitionName: `title-${post.id}`,
  },
});

const MetaBar = tasty({
  as: 'div',
  styles: {
    display: 'flex',
    flow: 'row',
    gap: '2x',
    alignItems: 'center',
    preset: 'overline',
    color: '#text-soft',
    viewTransitionName: `meta-${post.id}`,
  },
});

const TagsBar = tasty({
  as: 'div',
  styles: {
    display: 'flex',
    flow: 'row',
    gap: '1x',
    flexWrap: 'wrap',
    viewTransitionName: `tags-${post.id}`,
  },
});

const Article = tasty({
  as: 'article',
  styles: {
    display: 'flex',
    flow: 'column',
    gap: '2x',
    viewTransitionName: `description-${post.id}`,
  },
});

const BackLink = tasty({
  as: 'div',
  styles: {
    padding: '4x 0 0',
  },
});

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}

const postUrl = `https://tenphi.me/blog/${post.id}/`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString().split('T')[0],
  dateModified: post.data.date.toISOString().split('T')[0],
  url: postUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  image: `https://tenphi.me/og/blog/${post.id}.png`,
  author: {
    '@type': 'Person',
    name: 'Andrey Yamanov',
    url: 'https://tenphi.me',
  },
  publisher: {
    '@type': 'Person',
    name: 'Andrey Yamanov',
    url: 'https://tenphi.me',
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={`/og/blog/${post.id}.png`}
  publishedTime={post.data.date.toISOString().split('T')[0]}
  jsonLd={jsonLd}
  documentAtUri={documentRecord?.atUri}
>
  <Container>
    <Stack gap="0" padding="4x 0 8x">
      <Article>
        <MetaBar>
          <time datetime={post.data.date.toISOString().split('T')[0]}>
            {formatDate(post.data.date)}
          </time>
          <span>&middot;</span>
          <span>{readTime}</span>
        </MetaBar>
        <Heading>{post.data.title}</Heading>
        {
          post.data.tags?.length > 0 && (
            <TagsBar>
              {post.data.tags.map((tag: string) => (
                <Tag>{tag}</Tag>
              ))}
            </TagsBar>
          )
        }
        <ArticleContent>
          <Content />
        </ArticleContent>
      </Article>
      {
        thread ? (
          <Stack gap="4x" padding="6x 0 0">
            <EngagementBar
              postUrl={thread.postUrl}
              likeCount={thread.likeCount}
              repostCount={thread.repostCount}
              replyCount={thread.replyCount}
              followersCount={profile?.followersCount ?? null}
              profileUrl={site.bluesky.profileUrl}
            />
            <BlueskyComments
              replies={thread.replies}
              postUrl={thread.postUrl}
            />
          </Stack>
        ) : (
          <Stack gap="0" padding="6x 0 0">
            <Link
              href={site.bluesky.profileUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Discuss on Bluesky &rarr;
            </Link>
          </Stack>
        )
      }
      <BackLink>
        <Link href="/blog">&larr; Back to blog</Link>
      </BackLink>
    </Stack>
  </Container>
</BaseLayout>
