---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container';
import Stack from '../components/ui/Stack';
import ProjectCard from '../components/ProjectCard';
import projects from '../data/projects.json';
import { tasty } from '@tenphi/tasty';

const sectionNames = [
  'Personal',
  ...new Set(
    projects
      .map((project) => project.section)
      .filter((section) => section !== 'Personal'),
  ),
];

const Heading = tasty({
  as: 'h1',
  styles: {
    preset: 'h1',
    color: '#text',
    margin: '0',
  },
});

const Section = tasty({
  as: 'section',
  styles: {
    display: 'flex',
    flow: 'column',
    gap: '3x',

    SectionTitle: {
      $: 'h2',
      preset: 'h2',
      color: '#text',
      margin: '0',
    },
  },
});

const Grid = tasty({
  as: 'div',
  styles: {
    display: 'grid',
    gridColumns: '1fr',
    gap: '3x',
  },
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Portfolio — Andrey Yamanov',
  description:
    'Projects by Andrey Yamanov — Tasty ecosystem, open-source tools, and product work.',
  url: 'https://tenphi.me/portfolio',
  author: {
    '@type': 'Person',
    name: 'Andrey Yamanov',
    url: 'https://tenphi.me',
  },
};
---

<BaseLayout
  title="Portfolio"
  description="Projects by Andrey Yamanov — Tasty ecosystem, open-source tools, and product work."
  jsonLd={jsonLd}
>
  <Container>
    <Stack gap="6x" padding="4x 0 8x">
      <Heading>Portfolio</Heading>

      {
        sectionNames.map((sectionName) => (
          <Section>
            <h2>{sectionName}</h2>
            <Grid>
              {projects
                .filter((project) => project.section === sectionName)
                .map((project) => (
                  <ProjectCard {...project} />
                ))}
            </Grid>
          </Section>
        ))
      }
    </Stack>
  </Container>
</BaseLayout>
