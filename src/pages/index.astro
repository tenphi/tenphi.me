---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container';
import Stack from '../components/ui/Stack';
import Link from '../components/ui/Link';
import PostCard from '../components/PostCard';
import PostList from '../components/PostList';
import { tasty } from '@tenphi/tasty';
import readingTime from 'reading-time';

const recentPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const SectionHeading = tasty({
  as: 'div',
  styles: {
    display: 'flex',
    flow: 'row',
    justifyContent: 'space-between',
    alignItems: 'baseline',

    Title: {
      preset: 'h2',
      color: '#text-soft',
      margin: '0',
    },
  },
  elements: { Title: 'h2' },
});

const Hero = tasty({
  as: 'section',
  styles: {
    display: 'flex',
    flow: {
      '': 'row',
      '@mobile': 'column-reverse',
    },
    gap: '4x',
    alignItems: 'center',

    Content: {
      display: 'flex',
      flow: 'column',
      gap: '3x',
      flex: '1 1 auto',
    },
    Avatar: {
      display: 'block',
      width: '160px',
      height: 'auto',
      flex: '0 0 auto',
    },
    Heading: {
      $: 'h1',
      preset: 'h1',
      color: '#text',
      margin: '0',
    },
    Bio: {
      $: 'p',
      preset: 't1',
      color: '#text-soft',
      margin: '0',
    },
    Links: {
      display: 'flex',
      flow: 'row',
      gap: '1x',
      alignItems: 'center',
      flexWrap: 'wrap',
    },
  },
  elements: { Content: 'div', Avatar: 'img', Links: 'div' },
});

const SocialLink = tasty({
  as: 'a',
  styles: {
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'center',
    width: '5x',
    height: '5x',
    radius: '1r',
    color: {
      '': '#accent-text',
      ':hover': '#accent-text-2',
    },
    fill: {
      '': 'transparent',
      ':hover': '#accent-surface.08',
    },
    transition: 'theme',
  },
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Andrey Yamanov',
  jobTitle: 'Frontend Developer & Principal UX/UI Engineer',
  description:
    'Frontend Developer & Principal UX/UI Engineer. Building AI-ready, scalable design systems and UI components. Creator of Tasty and Glaze.',
  knowsAbout: [
    'Frontend Development',
    'Design Systems',
    'CSS-in-JS',
    'React',
    'TypeScript',
    'UX/UI Engineering',
  ],
  worksFor: {
    '@type': 'Organization',
    name: 'Cube Dev',
    url: 'https://cube.dev',
  },
  url: 'https://tenphi.me',
  sameAs: [
    'https://github.com/tenphi',
    'https://x.com/tenphi',
    'https://www.linkedin.com/in/tenphi',
    'https://facebook.com/tenphi',
    'https://t.me/tenphi',
  ],
};
---

<BaseLayout
  title="Andrey Yamanov"
  description="Frontend Developer & Principal UX/UI Engineer. Creator of Tasty and Glaze. Based in Amsterdam."
  jsonLd={jsonLd}
>
  <Container styles={{ flex: '1 1 auto', display: 'flex', flow: 'column', justifyContent: 'center', gap: '8x' }}>
    <Hero>
      <Hero.Content>
        <h1>Andrey Yamanov</h1>
        <p>
          Frontend Developer & Principal UX/UI Engineer at <Link
            href="https://cube.dev">Cube Dev</Link
          >. Building AI-ready, scalable design systems and UI components. Creator
          of <Link href="https://github.com/tenphi/tasty">Tasty</Link> and <Link
            href="https://github.com/tenphi/glaze">Glaze</Link
          >. Based in Amsterdam.
        </p>
        <Hero.Links>
          <SocialLink href="https://github.com/tenphi" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"></path></svg>
          </SocialLink>
          <SocialLink href="https://x.com/tenphi" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16l-4.267 0"></path><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path></svg>
          </SocialLink>
          <SocialLink href="https://www.linkedin.com/in/tenphi" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 11v5"></path><path d="M8 8v.01"></path><path d="M12 16v-5"></path><path d="M16 16v-3a2 2 0 1 0 -4 0"></path><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4l0 -10"></path></svg>
          </SocialLink>
          <SocialLink href="https://facebook.com/tenphi" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10v4h3v7h4v-7h3l1 -4h-4v-2a1 1 0 0 1 1 -1h3v-4h-3a5 5 0 0 0 -5 5v2h-3"></path></svg>
          </SocialLink>
          <SocialLink href="https://t.me/tenphi" target="_blank" rel="noopener noreferrer" aria-label="Telegram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10l-4 4l6 6l4 -16l-18 7l4 2l2 6l3 -4"></path></svg>
          </SocialLink>
        </Hero.Links>
      </Hero.Content>
      <Hero.Avatar src="/tenphi-full-avatar.svg" alt="Andrey Yamanov" width="160" height="160" />
    </Hero>
    {recentPosts.length > 0 && (
      <Stack gap="4x">
        <SectionHeading>
          <SectionHeading.Title>Recent Posts</SectionHeading.Title>
          <Link href="/blog">View all &rarr;</Link>
        </SectionHeading>
        <PostList>
          {recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              description={post.data.description}
              slug={post.id}
              readTime={readingTime(post.body ?? '').text}
              tags={post.data.tags}
            />
          ))}
        </PostList>
      </Stack>
    )}
  </Container>
</BaseLayout>
