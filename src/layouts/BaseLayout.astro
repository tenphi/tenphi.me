---
import '../config/tasty';
import GlobalStyles from '../components/GlobalStyles';
import Header from '../components/Header';
import Footer from '../components/Footer';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  publishedTime?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonicalUrl,
  ogType = 'website',
  ogImage,
  publishedTime,
  jsonLd,
} = Astro.props;

const siteTitle = `${title} — tenphi.me`;
const canonical = canonicalUrl || Astro.url.href;
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL('/og/default.png', Astro.site).href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Onest:wght@400;600;700&family=Source+Code+Pro:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Andrey Yamanov" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Andrey Yamanov — Blog"
      href="/rss.xml"
    />

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="tenphi.me" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {
      publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === 'article' && (
        <meta property="article:author" content="https://tenphi.me" />
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@AYamanov" />
    <meta name="twitter:creator" content="@AYamanov" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta
      name="theme-color"
      content="#f5f6f8"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1a1e2e"
      media="(prefers-color-scheme: dark)"
    />

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <GlobalStyles />
    <Header />
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'theme-preference';
        var radios = document.querySelectorAll('input[name="theme"]');

        var saved = localStorage.getItem(STORAGE_KEY);
        if (saved) {
          var target = document.querySelector(
            'input[name="theme"][value="' + saved + '"]',
          );
          if (target) target.checked = true;
        }

        radios.forEach(function (radio) {
          radio.addEventListener('change', function () {
            localStorage.setItem(STORAGE_KEY, this.value);
          });
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var KEY = 'high-contrast-preference';
        var radios = document.querySelectorAll('input[name="highContrast"]');

        var saved = localStorage.getItem(KEY);
        if (saved) {
          var target = document.querySelector(
            'input[name="highContrast"][value="' + saved + '"]',
          );
          if (target) target.checked = true;
        }

        radios.forEach(function (radio) {
          radio.addEventListener('change', function () {
            localStorage.setItem(KEY, this.value);
          });
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'hue-preference';
        var root = document.documentElement;

        // Marks that scripting is available: CSS swaps the 18-step radio track
        // (the JS-free fallback) for the continuous range slider below.
        root.setAttribute('data-js', '');

        var slider = document.querySelector('[data-hue-slider]');
        if (!slider) return;

        // The popover open/close is pure CSS (:focus-within). JS only powers
        // the hue slider, so enable it now that scripting is available.
        slider.disabled = false;

        function describe(value) {
          slider.setAttribute('aria-valuetext', value + ' degrees');
        }

        var saved = localStorage.getItem(STORAGE_KEY);
        if (saved != null) {
          root.style.setProperty('--primary-hue', saved);
          slider.value = saved;
        }
        describe(slider.value);

        slider.addEventListener('input', function () {
          root.style.setProperty('--primary-hue', this.value);
          localStorage.setItem(STORAGE_KEY, this.value);
          describe(this.value);
        });
      })();
    </script>
    <script is:inline>
      (function () {
        // Progressive enhancement for the appearance popover. The panel opens
        // purely via CSS `:focus-within`; this adds the accessible extras that
        // need scripting: syncing `aria-expanded`, closing on Escape, and a
        // click-to-toggle trigger — all while keeping focus on the button.
        var widgets = document.querySelectorAll('[data-appearance]');
        widgets.forEach(function (root) {
          var button = root.querySelector('[data-appearance-button]');
          if (!button) return;

          function setExpanded(open) {
            button.setAttribute('aria-expanded', open ? 'true' : 'false');
          }
          setExpanded(false);

          // Snapshot open state at interaction start so a click that both
          // focuses and opens the panel isn't immediately toggled shut.
          var wasOpen = false;
          function snapshot() {
            wasOpen =
              root.contains(document.activeElement) &&
              !root.hasAttribute('data-collapsed');
          }
          button.addEventListener('pointerdown', snapshot);
          button.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') snapshot();
          });
          button.addEventListener('click', function () {
            if (wasOpen) {
              root.setAttribute('data-collapsed', '');
              setExpanded(false);
            } else {
              root.removeAttribute('data-collapsed');
              setExpanded(true);
            }
            button.focus();
          });

          root.addEventListener('focusin', function () {
            if (!root.hasAttribute('data-collapsed')) setExpanded(true);
          });
          root.addEventListener('focusout', function (e) {
            if (!root.contains(e.relatedTarget)) {
              root.removeAttribute('data-collapsed');
              setExpanded(false);
            }
          });

          root.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && !root.hasAttribute('data-collapsed')) {
              root.setAttribute('data-collapsed', '');
              setExpanded(false);
              button.focus();
              e.stopPropagation();
            }
          });
        });
      })();
    </script>
    <main style="flex: 1 1 auto; display: flex; flex-direction: column;">
      <slot />
    </main>
    <Footer />
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="070eff0b-1d9d-4e04-bbe2-8cff06879500"></script>
  </body>
</html>
