---
import '../config/tasty';
import GlobalStyles from '../components/GlobalStyles';
import Header from '../components/Header';
import Footer from '../components/Footer';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  publishedTime?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonicalUrl,
  ogType = 'website',
  ogImage,
  publishedTime,
  jsonLd,
} = Astro.props;

const siteTitle = `${title} — tenphi.me`;
const canonical = canonicalUrl || Astro.url.href;
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL('/og/default.png', Astro.site).href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Onest:wght@400;600;700&family=Source+Code+Pro:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Andrey Yamanov" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Andrey Yamanov — Blog"
      href="/rss.xml"
    />

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="tenphi.me" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {
      publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === 'article' && (
        <meta property="article:author" content="https://tenphi.me" />
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@AYamanov" />
    <meta name="twitter:creator" content="@AYamanov" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta
      name="theme-color"
      content="#f5f6f8"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1a1e2e"
      media="(prefers-color-scheme: dark)"
    />

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <GlobalStyles />
    <Header />
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'theme-preference';
        var radios = document.querySelectorAll('input[name="theme"]');

        var saved = localStorage.getItem(STORAGE_KEY);
        if (saved) {
          var target = document.querySelector(
            'input[name="theme"][value="' + saved + '"]',
          );
          if (target) target.checked = true;
        }

        radios.forEach(function (radio) {
          radio.addEventListener('change', function () {
            localStorage.setItem(STORAGE_KEY, this.value);
          });
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'hue-preference';
        var root = document.documentElement;
        var btn = document.querySelector('[data-hue-toggle]');
        var popover = document.querySelector('[data-hue-popover]');
        var slider = document.querySelector('[data-hue-slider]');

        var saved = localStorage.getItem(STORAGE_KEY);
        if (saved != null && slider) {
          root.style.setProperty('--primary-hue', saved);
          slider.value = saved;
        }

        if (btn && popover) {
          btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var open = popover.getAttribute('data-open') === 'true';
            popover.setAttribute('data-open', String(!open));
            btn.setAttribute('aria-expanded', String(!open));
          });
          document.addEventListener('click', function (e) {
            if (popover.getAttribute('data-open') !== 'true') return;
            if (
              !popover.contains(e.target) &&
              e.target !== btn &&
              !btn.contains(e.target)
            ) {
              popover.setAttribute('data-open', 'false');
              btn.setAttribute('aria-expanded', 'false');
            }
          });
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
              popover.setAttribute('data-open', 'false');
              btn.setAttribute('aria-expanded', 'false');
            }
          });
        }

        if (slider) {
          slider.addEventListener('input', function () {
            root.style.setProperty('--primary-hue', this.value);
            localStorage.setItem(STORAGE_KEY, this.value);
          });
        }
      })();
    </script>
    <main style="flex: 1 1 auto; display: flex; flex-direction: column;">
      <slot />
    </main>
    <Footer />
    <script
      data-goatcounter="https://tenphi-me.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"></script>
  </body>
</html>
